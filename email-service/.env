APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
DEFAULT_URI=http://localhost

LANGUAGE_DETECTOR_URL=http://language-detector:8090
LANGUAGE_DETECTOR_CONFIDENCE_THRESHOLD=0.5

OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TEMPERATURE_INCIDENT=0.1
OLLAMA_TEMPERATURE_EMOTIONS=0.4
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

WEAVIATE_URL=http://weaviate:8080
WEAVIATE_SIMILAR_INCIDENT_LIMIT=5
